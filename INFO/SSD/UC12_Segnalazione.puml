@startuml SSD_UC12_Segnalazione
' System Sequence Diagram - UC12 Aprire una segnalazione
title SSD - UC12 Aprire una segnalazione

skinparam sequenceMessageAlign center
skinparam participant {
  BorderColor black
  BackgroundColor white
}

actor "Utente / Business" as U
participant "System\n:NerdVault" as S

U -> S : apriFormSegnalazione(idAnnuncio?)  <GET /segnalazione/create/{id}>
activate S
S --> U : form (id annuncio precompilato se da dettaglio)
deactivate S

U -> S : creaSegnalazione(tipologia, descrizione, oggetto{annuncio|utente|business|feedback}, csrfToken)  <POST /segnalazione/store>
activate S
S --> U : segnalazione salvata (stato Aperta)
deactivate S

note over U, S
  Tipologie: Spam, Truffa, Contenuto_inappropriato, Altro.
  Alternative: tipologia non valida, nessun oggetto o piu oggetti -> errore
end note
@enduml
