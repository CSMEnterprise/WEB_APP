      "text": "CREATE TABLE categorie (\n    id INT AUTO_INCREMENT PRIMARY KEY,\n    nome VARCHAR(100) NOT NULL,\n    id_padre INT DEFAULT NULL,\n    FOREIGN KEY (id_padre) REFERENCES categorie(id) \n        ON DELETE CASCADE \n        ON UPDATE CASCADE\n);",
