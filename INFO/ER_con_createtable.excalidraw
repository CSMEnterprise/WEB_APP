      "text": "CREATE TABLE Pagamento (\n  id_pagamento      INT AUTO_INCREMENT PRIMARY KEY,\n  id_annuncio       INT NOT NULL,\n  id_acquirente     INT NOT NULL,\n  importo_totale    DECIMAL(10,2) NOT NULL,\n  metodo_pagamento  ENUM('Carta','Paypal','Bonifico','Contanti') NOT NULL,\n  stato             ENUM('In_attesa','Completato','Annullato','Rimborsato') NOT NULL DEFAULT 'In_attesa',\n  data              TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  FOREIGN KEY (id_annuncio)   REFERENCES Annuncio(id_annuncio),\n  FOREIGN KEY (id_acquirente) REFERENCES Utente_registrato(id_utente)\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE Pagamento (\n  id_pagamento      INT AUTO_INCREMENT PRIMARY KEY,\n  id_annuncio       INT NOT NULL,\n  id_acquirente     INT NOT NULL,\n  importo_totale    DECIMAL(10,2) NOT NULL,\n  metodo_pagamento  ENUM('Carta','Paypal','Bonifico','Contanti') NOT NULL,\n  stato             ENUM('In_attesa','Completato','Annullato','Rimborsato') NOT NULL DEFAULT 'In_attesa',\n  data              TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  FOREIGN KEY (id_annuncio)   REFERENCES Annuncio(id_annuncio),\n  FOREIGN KEY (id_acquirente) REFERENCES Utente_registrato(id_utente)\n);",
      "autoResize": true,
      "lineHeight": 1.25
    },
