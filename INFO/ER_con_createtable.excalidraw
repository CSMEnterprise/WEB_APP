      "link": null,
      "locked": false,
      "text": "CREATE TABLE Feedback (\n  id_feedback     INT AUTO_INCREMENT PRIMARY KEY,\n  id_utente       INT NOT NULL,\n  id_annuncio     INT,\n  id_pagamento    INT NOT NULL,\n  valutazione     TINYINT NOT NULL CHECK (valutazione BETWEEN 1 AND 5),\n  commento        TEXT,\n  data_feedback   TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  FOREIGN KEY (id_utente)    REFERENCES Utente_registrato(id_utente),\n  FOREIGN KEY (id_annuncio)  REFERENCES Annuncio(id_annuncio),\n  FOREIGN KEY (id_pagamento) REFERENCES Pagamento(id_pagamento)\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
