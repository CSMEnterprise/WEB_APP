      "text": "CREATE TABLE SEGNALAZIONE (\n    ID_segnalazione   SERIAL PRIMARY KEY,\n    ID_utente         INT NOT NULL,\n    ID_annuncio       INT,          -- nullable, dipende cosa si segnala\n    ID_feedback       INT,          -- nullable, se si segnala un feedback\n    ID_oggetto        INT,\n    Tipo_oggetto      VARCHAR(100),\n    Tipologia         VARCHAR(100), -- truffa, spam...\n    Data_segnalazione DATE NOT NULL,\n\n    FOREIGN KEY (ID_utente)   REFERENCES UTENTE_REGISTRATO(ID_utente),\n    FOREIGN KEY (ID_annuncio) REFERENCES ANNUNCIO(ID_annuncio),\n    FOREIGN KEY (ID_feedback) REFERENCES FEEDBACK(ID_feedback)\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE SEGNALAZIONE (\n    ID_segnalazione   SERIAL PRIMARY KEY,\n    ID_utente         INT NOT NULL,\n    ID_annuncio       INT,          -- nullable, dipende cosa si segnala\n    ID_feedback       INT,          -- nullable, se si segnala un feedback\n    ID_oggetto        INT,\n    Tipo_oggetto      VARCHAR(100),\n    Tipologia         VARCHAR(100), -- truffa, spam...\n    Data_segnalazione DATE NOT NULL,\n\n    FOREIGN KEY (ID_utente)   REFERENCES UTENTE_REGISTRATO(ID_utente),\n    FOREIGN KEY (ID_annuncio) REFERENCES ANNUNCIO(ID_annuncio),\n    FOREIGN KEY (ID_feedback) REFERENCES FEEDBACK(ID_feedback)\n);",
      "autoResize": true,
      "lineHeight": 1.25
