      "updated": 1776355287659,
      "link": null,
      "locked": false,
      "text": "CREATE TABLE Admin (\n  id_admin  INT AUTO_INCREMENT PRIMARY KEY,\n  email   VARCHAR(255) NOT NULL UNIQUE,\n  password_hash   VARCHAR(255) NOT NULL,\n  livello_sicurezza INT NOT NULL DEFAULT 1,\n  data_creazione  TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
