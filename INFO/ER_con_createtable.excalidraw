      "text": "CREATE TABLE Annuncio (\n  id_annuncio       INT AUTO_INCREMENT PRIMARY KEY,\n  id_utente         INT,\n  id_business       INT,\n  id_categoria      INT NOT NULL,\n  titolo            VARCHAR(255) NOT NULL,\n  descrizione       TEXT,\n  stato_conservazione ENUM('Nuovo','Ottimo','Buono','Discreto','Da restaurare') NOT NULL,\n  prezzo            DECIMAL(10,2) NOT NULL,\n  modalita_consegna ENUM('Spedizione','Ritiro_a_mano','Entrambi') NOT NULL,\n  stato             ENUM('attivo','venduto','scaduto','rimosso') NOT NULL DEFAULT 'attivo',\n  data_creazione    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  data_scadenza     TIMESTAMP,\n  FOREIGN KEY (id_utente)    REFERENCES Utente_registrato(id_utente),\n  FOREIGN KEY (id_categoria) REFERENCES Categoria(id_categoria),\n  FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n  CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL)\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE Annuncio (\n  id_annuncio       INT AUTO_INCREMENT PRIMARY KEY,\n  id_utente         INT,\n  id_business       INT,\n  id_categoria      INT NOT NULL,\n  titolo            VARCHAR(255) NOT NULL,\n  descrizione       TEXT,\n  stato_conservazione ENUM('Nuovo','Ottimo','Buono','Discreto','Da restaurare') NOT NULL,\n  prezzo            DECIMAL(10,2) NOT NULL,\n  modalita_consegna ENUM('Spedizione','Ritiro_a_mano','Entrambi') NOT NULL,\n  stato             ENUM('attivo','venduto','scaduto','rimosso') NOT NULL DEFAULT 'attivo',\n  data_creazione    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  data_scadenza     TIMESTAMP,\n  FOREIGN KEY (id_utente)    REFERENCES Utente_registrato(id_utente),\n  FOREIGN KEY (id_categoria) REFERENCES Categoria(id_categoria),\n  FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n  CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL)\n);",
      "autoResize": true,
      "lineHeight": 1.25
    },
