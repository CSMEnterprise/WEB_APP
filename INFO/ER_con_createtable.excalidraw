      "text": "CREATE TABLE Modera (\n    id_moderazione INT AUTO_INCREMENT PRIMARY KEY,\n    id_admin INT NOT NULL,\n    id_utente INT,\n    id_feedback INT,\n    id_annuncio INT,\n    id_business INT,\n    entita_colpita ENUM('Feedback', 'Annuncio', 'Utente','Account_Business'),\n    id_entita_colpita INT,\n    azione_compiuta TEXT, \n    data_azione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    \n    FOREIGN KEY (id_utente) REFERENCES Utente_registrato(id_utente),\n    FOREIGN KEY (id_admin)    REFERENCES Admin(id_admin),\n    FOREIGN KEY (id_feedback) REFERENCES Feedback(id_feedback),\n    FOREIGN KEY (id_annuncio) REFERENCES Annuncio(id_annuncio),\n    FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n   CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL OR id_annuncio IS NOT NULL OR id_feedback IS NOT NULL)\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE Modera (\n    id_moderazione INT AUTO_INCREMENT PRIMARY KEY,\n    id_admin INT NOT NULL,\n    id_utente INT,\n    id_feedback INT,\n    id_annuncio INT,\n    id_business INT,\n    entita_colpita ENUM('Feedback', 'Annuncio', 'Utente','Account_Business'),\n    id_entita_colpita INT,\n    azione_compiuta TEXT, \n    data_azione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    \n    FOREIGN KEY (id_utente) REFERENCES Utente_registrato(id_utente),\n    FOREIGN KEY (id_admin)    REFERENCES Admin(id_admin),\n    FOREIGN KEY (id_feedback) REFERENCES Feedback(id_feedback),\n    FOREIGN KEY (id_annuncio) REFERENCES Annuncio(id_annuncio),\n    FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n   CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL OR id_annuncio IS NOT NULL OR id_feedback IS NOT NULL)\n);",
      "autoResize": true,
      "lineHeight": 1.25
    },
