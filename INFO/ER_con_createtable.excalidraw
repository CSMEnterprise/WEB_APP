      "text": "CREATE TABLE Gestisce (\n    id_admin INT,\n    id_segnalazione INT NOT NULL,\n    data_presa_in_carico TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    note_admin TEXT, \n    stato_gestione ENUM('in_attesa', 'presa_in_carico', 'risolta') DEFAULT 'in_attesa',\n\n    PRIMARY KEY (id_admin, id_segnalazione),\n    FOREIGN KEY (id_admin) REFERENCES Admin(id_admin),\n    FOREIGN KEY (id_segnalazione) REFERENCES Segnalazione(id_segnalazione) ON DELETE CASCADE\n);",
