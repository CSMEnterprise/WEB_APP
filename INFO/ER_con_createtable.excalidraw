      "text": "CREATE TABLE Segnalazione (\n  id_segnalazione  INT AUTO_INCREMENT PRIMARY KEY,\n  id_utente      INT,\n  id_annuncio      INT,\n  id_business      INT,\n  id_oggetto       INT NOT NULL,\n  id_feedback       INT,\n  tipo_oggetto     ENUM('Annuncio','Utente','Feedback') NOT NULL,\n  tipologia        ENUM('Spam','Truffa','Contenuto_inappropriato','Altro') NOT NULL,\n  descrizione      TEXT,\n  stato            ENUM('Aperta','In_revisione','Risolta') NOT NULL DEFAULT 'Aperta',\n  data_segnalazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  id_admin         INT,\n  data_risoluzione TIMESTAMP,\n\n  FOREIGN KEY (id_utente) REFERENCES Utente_registrato(id_utente),\n  FOREIGN KEY (id_admin)    REFERENCES Admin(id_admin),\n  FOREIGN KEY (id_feedback) REFERENCES Feedback(id_feedback),\n  FOREIGN KEY (id_annuncio) REFERENCES Annuncio(id_annuncio),\n  FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL)\n\n);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE Segnalazione (\n  id_segnalazione  INT AUTO_INCREMENT PRIMARY KEY,\n  id_utente      INT,\n  id_annuncio      INT,\n  id_business      INT,\n  id_oggetto       INT NOT NULL,\n  id_feedback       INT,\n  tipo_oggetto     ENUM('Annuncio','Utente','Feedback') NOT NULL,\n  tipologia        ENUM('Spam','Truffa','Contenuto_inappropriato','Altro') NOT NULL,\n  descrizione      TEXT,\n  stato            ENUM('Aperta','In_revisione','Risolta') NOT NULL DEFAULT 'Aperta',\n  data_segnalazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n  id_admin         INT,\n  data_risoluzione TIMESTAMP,\n\n  FOREIGN KEY (id_utente) REFERENCES Utente_registrato(id_utente),\n  FOREIGN KEY (id_admin)    REFERENCES Admin(id_admin),\n  FOREIGN KEY (id_feedback) REFERENCES Feedback(id_feedback),\n  FOREIGN KEY (id_annuncio) REFERENCES Annuncio(id_annuncio),\n  FOREIGN KEY (id_business) REFERENCES Account_Business(id_acc_business),\n\n CHECK (id_utente IS NOT NULL OR id_business IS NOT NULL)\n\n);",
      "autoResize": true,
      "lineHeight": 1.25
