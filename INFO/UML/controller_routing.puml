@startuml controller_routing
' Routing e controller applicativi - NerdVault
title NerdVault - Routing e controller

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam ArrowColor #444444
skinparam classAttributeIconSize 0
skinparam class {
  BorderColor #555555
  BackgroundColor #F5F7FA
  HeaderBackgroundColor #E3E8EF
}
skinparam note {
  BorderColor #B8860B
  BackgroundColor #FFF8DC
}

left to right direction

' ── Pipeline del Front Controller ────────────────────────
class FrontController {
  + handle()
  - dispatch(segments) : bool
  - matchRoute(segments)
  - methodAllowed(route) : bool
  - csrfAllowed() : bool
  - callController(class, action, params)
}

note top of FrontController
  Pipeline di ogni richiesta:
  1. normalizza URL in segmenti
  2. matchRoute() -> controller/action
  3. verifica metodo HTTP (GET/POST)
  4. valida token CSRF sui POST
  5. esegue i middleware della route
  6. invoca controller->action(...params)
end note

abstract class BaseController {
  # view(template, data, title)
  # renderError(message, status)
  # requirePositiveId(id)
  # denyBusinessBuyer(id)
  # registerAdminAction(...)
}

package "Middleware (funzioni)" as MW {
  class Accesso <<functions>> {
  requireAuth() / requireGuest()
  requireAdmin() / requireAdminLivello2()
  requireBusiness()
  denyAdmin() / denyBusiness()
  currentUserId()
  }
}

' ── Controller applicativi ───────────────────────────────
class HomeController {
  + index()
}
class AnnuncioController {
  + lista() / dettaglio(id)
  + formCreazione() / crea(data, id, files)
  + formModifica(id, id) / aggiorna(...)
  + eliminaImmagine(...) / elimina(id, id)
}
class UtenteController {
  + loginFormOrSubmit() / logout()
  + registerUserFormOrSubmit() / registerBusinessFormOrSubmit()
  + verificaEmail(token) / reinviaVerifica()
  + passwordRecoveryFormOrSubmit() / passwordResetFormOrSubmit()
  + profiloCorrente() / venditore(id)
  + aggiornaProfiloUtente() / cambiaPassword()
  + salvaIndirizzoSpedizione() / aggiornaIndirizzo() / eliminaIndirizzo()
}
class CarrelloController {
  + lista(id) / aggiungi(id, id)
  + rimuovi(id, id) / svuota(id)
}
class WishlistController {
  + lista(id) / aggiungi(id, id)
  + rimuovi(id, id) / toggle(id, id) / svuota(id)
}
class PagamentoController {
  + checkout() / checkoutCarrello()
  + paypalPlaceholder() / paypalPlaceholderCarrello()
  + conferma() / confermaCarrello()
  + paypalCancel() / esito()
}
class BusinessController {
  + dashboard(id) / formCreazione()
  + creaAccount() / ordini(id)
  + salvaInfo() / salvaIndirizzo()
}
class FeedbackController {
  + lista(id) / form(idPag, idAutore)
  + crea(data, id) / listaVenditore(id)
}
class SegnalazioneController {
  + form(idAnnuncio) / crea(data, id)
  + chiudi(id, idAdmin) / elimina(id, idAdmin)
}
class AdminController {
  + dashboard(id) / dashboardModerazione(filtri)
  + utenti(filtri) / segnalazioni(filtri)
  + bannaUtente() / sbloccaUtente()
  + bannaAdmin() / sbloccaAdmin()
}
class LegalController {
  + privacy() / termini() / cookie()
}

' ── Relazioni ────────────────────────────────────────────
FrontController ..> Accesso : esegue per route
FrontController ..> HomeController : dispatch
FrontController ..> AnnuncioController : dispatch
FrontController ..> UtenteController : dispatch
FrontController ..> CarrelloController : dispatch
FrontController ..> WishlistController : dispatch
FrontController ..> PagamentoController : dispatch
FrontController ..> BusinessController : dispatch
FrontController ..> FeedbackController : dispatch
FrontController ..> SegnalazioneController : dispatch
FrontController ..> AdminController : dispatch
FrontController ..> LegalController : dispatch

FrontController --|> BaseController
HomeController --|> BaseController
AnnuncioController --|> BaseController
UtenteController --|> BaseController
CarrelloController --|> BaseController
WishlistController --|> BaseController
PagamentoController --|> BaseController
BusinessController --|> BaseController
FeedbackController --|> BaseController
SegnalazioneController --|> BaseController
AdminController --|> BaseController
LegalController --|> BaseController

@enduml
