@startuml
title NerdVault - Diagramma classi Foundation

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

top to bottom direction

package "Infrastruttura persistenza" {
  class FDataBase <<Singleton PDO>> {
    - instance: FDataBase
    - db: PDO
    + init(db: PDO): FDataBase
    + getInstance(): FDataBase
    + getConnection(): PDO
    + transaction(callback): mixed
    + table(foundationClass): object
  }

  abstract class FBaseTable <<Template repository>> {
    # db: PDO
    # tableName(): string
    # primaryKey(): string
    # entityClass(): string
    # columns(): array
    + find(id): EBaseEntity
    + insert(source): int
    + updateById(id, source): bool
    + deleteById(id): bool
    # fetchEntity(sql, params): EBaseEntity
    # fetchEntities(sql, params): array
    # execute(sql, params): int
  }

  class FPersistentManager <<Facade>> {
    + store(entity): int
    + load(field, value, foundationClass): mixed
    + transaction(callback): mixed
    + confirmSinglePayment(...): int
    + confirmCartPayment(...): array
    + dashboardStats(): array
  }
}

package "Catalogo e annunci" {
  class FAnnuncio {
    + attivi(idCategoria): array
    + findWithDetails(idAnnuncio): EAnnuncio
    + createForUser(annuncio, idUtente): int
    + createForBusiness(annuncio, idBusiness): int
    + updateForOwner(...): bool
    + search(...): array
    + markSoldIfActive(idAnnuncio): bool
  }

  class FCategoria {
    + allNested(): array
  }

  class FImmagine {
    + byAnnuncio(idAnnuncio): array
    + addForAnnuncio(idAnnuncio, url, ordine): int
    + findOwnedByUser(idImmagine, idUtente): mixed
  }
}

package "Utenti, ruoli e profili" {
  class FUtenteRegistrato {
    + findByEmailForLogin(email): EUtenteRegistrato
    + createWithVerification(...): int
    + confirmEmail(idUtente): void
    + updateProfile(...): void
    + setBanState(idUtente, banned): void
  }

  class FAccountBusiness {
    + findByUserWithAddress(idUtente): EAccountBusiness
    + create(business): int
    + updateInfo(idBusiness, data): bool
  }

  class FAdmin {
    + findByEmailForLogin(email): EAdmin
    + allOrdered(): array
    + findForModeration(idAdmin): EAdmin
    + setBanState(idAdmin, banned): void
  }

  class FIndirizzo {
    + byUser(idUtente): array
    + findForUser(idIndirizzo, idUtente): EIndirizzo
    + setDefault(idUtente, idIndirizzo): void
    + updateForUser(indirizzo): void
  }

  class FPasswordReset {
    + createForUser(idUtente, token, scadenza): int
    + findUsableByToken(token): EPasswordReset
    + markTokenUsed(token): void
  }
}

package "Acquisto, carrello e feedback" {
  class FCarrello {
    + getOrCreateIdByUser(idUtente): int
    + activeItemCountByUser(idUtente): int
  }

  class FElementoCarrello {
    + purchasableByCart(idCarrello): array
    + add(elemento): void
    + remove(idCarrello, idAnnuncio): void
    + clearCart(idCarrello): void
  }

  class FPreferito {
    + annunciByUser(idUtente): array
    + add(preferito): void
    + remove(idUtente, idAnnuncio): void
    + existsForUser(idUtente, idAnnuncio): bool
  }

  class FPagamento {
    + create(pagamento): int
    + chronologyByUser(idUtente): array
    + receivedBySellerUser(idUtente): array
    + receivedBySellerBusiness(idBusiness): array
  }

  class FFeedback {
    + create(feedback): int
    + byUser(idUtente): array
    + byVenditore(idVenditore): array
    + mediaVenditore(idVenditore): float
  }
}

package "Moderazione" {
  class FSegnalazione {
    + create(segnalazione): int
    + allWithDetails(filters): array
    + close(idSegnalazione, idAdmin): void
  }

  class FModera {
    + create(moderazione): int
    + byAdmin(idAdmin): array
    + withAdminDetails(filters): array
  }
}

FBaseTable <|-- FAnnuncio
FBaseTable <|-- FCategoria
FBaseTable <|-- FImmagine
FBaseTable <|-- FUtenteRegistrato
FBaseTable <|-- FAccountBusiness
FBaseTable <|-- FAdmin
FBaseTable <|-- FIndirizzo
FBaseTable <|-- FPasswordReset
FBaseTable <|-- FCarrello
FBaseTable <|-- FElementoCarrello
FBaseTable <|-- FPreferito
FBaseTable <|-- FPagamento
FBaseTable <|-- FFeedback
FBaseTable <|-- FSegnalazione
FBaseTable <|-- FModera

FPersistentManager ..> FDataBase : ottiene connessione
FDataBase ..> FBaseTable : istanzia repository
FBaseTable ..> EBaseEntity : idrata entity
FAnnuncio *-- FImmagine : usa per dettaglio immagini

FPersistentManager ..> FAnnuncio
FPersistentManager ..> FUtenteRegistrato
FPersistentManager ..> FAccountBusiness
FPersistentManager ..> FAdmin
FPersistentManager ..> FCarrello
FPersistentManager ..> FElementoCarrello
FPersistentManager ..> FPreferito
FPersistentManager ..> FPagamento
FPersistentManager ..> FFeedback
FPersistentManager ..> FSegnalazione
FPersistentManager ..> FModera

note right of FPersistentManager
Facade usata dai controller.
Nasconde l'istanziazione delle singole
Foundation e coordina operazioni composte.
end note

note bottom of FBaseTable
Classe base comune: CRUD generico,
query helper, whitelist colonne
e conversione righe SQL in Entity.
end note

@enduml
