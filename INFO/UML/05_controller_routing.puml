@startuml
title NerdVault - Diagramma classi Controller e Routing

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

left to right direction

package "Core routing" {
  class FrontController {
    + handle(): void
    - dispatch(segments): bool
    - routes(): array
    - requestSegments(): array
    - matchRoute(segments): array
    - callController(className, action, params): bool
    - methodAllowed(route): bool
    - csrfAllowed(): bool
  }

  class Request {
    + get(key, default): mixed
    + post(key, default): mixed
    + files(): array
    + server(key, default): mixed
  }

  class Csrf {
    + token(): string
    + fieldName(): string
    + validate(token): bool
  }

  class SessionManager {
    + start(): void
    + get(key, default): mixed
    + set(key, value): void
    + has(key): bool
  }
}

package "Base controller" {
  abstract class BaseController {
    # view(template, data, pageTitle): void
    # renderError(message, statusCode): void
    # requirePositiveId(id, fieldName): void
    # denyBusinessBuyer(idUtente): void
    # clean(value): string
    # registerAdminAction(...): void
  }
}

package "Controller pubblici" {
  class HomeController {
    + index(): void
  }

  class LegalController {
    + privacy(): void
    + termini(): void
    + cookie(): void
  }
}

package "Controller utente e account" {
  class UtenteController {
    + loginFormOrSubmit(data): void
    + registerUserFormOrSubmit(data): void
    + registerBusinessFormOrSubmit(data): void
    + profilo(idUtente, filtro): void
    + venditore(idVenditore): void
    + aggiornaFotoProfilo(files, idUtente): void
    + cambiaPassword(data, idUtente): void
    + verificaEmail(token): void
    + passwordResetFormOrSubmit(data, token): void
  }

  class BusinessController {
    + dashboard(idUtente): void
    + creaAccount(data, idUtente): void
    + salvaInfo(data, idUtente): void
    + salvaIndirizzo(data, idUtente): void
    + ordini(idUtente): void
  }
}

package "Controller marketplace" {
  class AnnuncioController {
    + lista(): void
    + dettaglio(idAnnuncio): void
    + formCreazione(): void
    + crea(data, idUtente, files): void
    + aggiorna(data, idUtente, files): void
    + eliminaImmagine(data, idUtente): void
    + elimina(idAnnuncio, idUtente): void
  }

  class WishlistController {
    + lista(idUtente): void
    + aggiungi(idUtente, idAnnuncio): void
    + rimuovi(idUtente, idAnnuncio): void
    + toggle(idUtente, idAnnuncio): void
    + svuota(idUtente): void
  }

  class CarrelloController {
    + lista(idUtente): void
    + aggiungi(idUtente, idAnnuncio): void
    + rimuovi(idUtente, idAnnuncio): void
    + svuota(idUtente): void
  }

  class PagamentoController {
    + checkout(idUtente, idAnnuncio): void
    + checkoutCarrello(idUtente): void
    + conferma(data, idUtente): void
    + confermaCarrello(data, idUtente): void
    + esito(): void
  }

  class FeedbackController {
    + form(idPagamento, idAutore): void
    + crea(data, idAutore): void
    + lista(idUtente): void
    + listaVenditore(idVenditore): void
  }
}

package "Controller moderazione" {
  class SegnalazioneController {
    + form(idAnnuncio): void
    + crea(data, idSegnalante): void
    + chiudi(idSegnalazione, idAdmin): void
    + elimina(idSegnalazione, idAdmin): void
  }

  class AdminController {
    + dashboard(idAdmin): void
    + utenti(filters): void
    + segnalazioni(filters): void
    + bannaUtente(idUtente, idAdmin): void
    + sbloccaUtente(idUtente, idAdmin): void
    + bannaAdmin(idAdminDaBannare, idAdminCorrente): void
    + sbloccaAdmin(idAdminDaSbloccare, idAdminCorrente): void
  }
}

package "Middleware" {
  class "requireAuth()" as RequireAuth
  class "requireGuest()" as RequireGuest
  class "requireAdmin()" as RequireAdmin
  class "requireAdminLivello2()" as RequireAdmin2
  class "requireBusiness()" as RequireBusiness
  class "denyAdmin()" as DenyAdmin
  class "denyBusiness()" as DenyBusiness
}

FrontController --|> BaseController
HomeController --|> BaseController
LegalController --|> BaseController
UtenteController --|> BaseController
BusinessController --|> BaseController
AnnuncioController --|> BaseController
WishlistController --|> BaseController
CarrelloController --|> BaseController
PagamentoController --|> BaseController
FeedbackController --|> BaseController
SegnalazioneController --|> BaseController
AdminController --|> BaseController

FrontController ..> HomeController : /home
FrontController ..> LegalController : /legale
FrontController ..> UtenteController : /auth, /utente
FrontController ..> BusinessController : /business
FrontController ..> AnnuncioController : /annuncio
FrontController ..> WishlistController : /wishlist
FrontController ..> CarrelloController : /carrello
FrontController ..> PagamentoController : /pagamento
FrontController ..> FeedbackController : /feedback
FrontController ..> SegnalazioneController : /segnalazione
FrontController ..> AdminController : /admin

FrontController ..> RequireAuth
FrontController ..> RequireGuest
FrontController ..> RequireAdmin
FrontController ..> RequireAdmin2
FrontController ..> RequireBusiness
FrontController ..> DenyAdmin
FrontController ..> DenyBusiness
FrontController ..> Request : metodo, URL e parametri
FrontController ..> Csrf : valida POST
FrontController ..> SessionManager : utente corrente

BaseController ..> SmartyView : render view
BaseController ..> FPersistentManager : operazioni dati
UtenteController ..> MailService : email
AnnuncioController ..> FPersistentManager : annunci / immagini
PagamentoController ..> FPersistentManager : transazioni pagamento
AdminController ..> FPersistentManager : moderazione

note top of FrontController
Il router e definito in routes().
Ogni route associa path, middleware,
controller, action, parametri e,
quando necessario, metodi HTTP.
Le richieste POST sono validate
tramite token CSRF.
end note

note bottom of BaseController
Contiene funzionalita comuni,
ma non sostituisce i controller specifici.
end note

@enduml
