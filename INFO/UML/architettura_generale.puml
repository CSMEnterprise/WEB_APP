@startuml architettura_generale
' Architettura generale del framework MVC - NerdVault
title NerdVault - Architettura generale (MVC a livelli)

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam ArrowColor #444444
skinparam componentStyle rectangle
skinparam rectangle {
  BorderColor #555555
  BackgroundColor #F5F7FA
}
skinparam package {
  BorderColor #2C3E50
  BackgroundColor #FFFFFF
  FontStyle bold
}

actor "Client / Browser" as Client

package "Web server (Apache / XAMPP)" as Web {
  rectangle ".htaccess\n(URL rewriting)" as Htaccess
  rectangle "public/index.php\n(bootstrap + entry point)" as Index
}

package "Livello Core" as Core {
  rectangle "FrontController\nrouting, middleware,\nCSRF, dispatch" as Front
  rectangle "Request\nGET / POST / FILES / SERVER" as Request
  rectangle "SessionManager\nsessione e ruoli" as Session
  rectangle "Csrf\ngenera / valida token" as Csrf
  rectangle "UploadedFile\nfile caricato" as Upload
}

package "Livello Controller" as Ctrl {
  rectangle "BaseController\nview(), errori,\nvalidazioni comuni" as Base
  rectangle "Controller applicativi\nHome, Utente, Annuncio, Carrello,\nWishlist, Pagamento, Feedback,\nSegnalazione, Business, Admin, Legal" as Controllers
  rectangle "Middleware\nrequireAuth / Guest /\nAdmin / Business" as Middleware
  rectangle "Servizi\nMailService,\nServiceException" as Services
}

package "Livello View" as View {
  rectangle "SmartyView\nrender template" as Smarty
  rectangle "ViewDataNormalizer\nnormalizza dati" as Normalizer
  rectangle "templates/*.tpl" as Templates
}

package "Livello Model / Persistenza" as Model {
  rectangle "FPersistentManager\nfacade del layer Foundation" as PM
  rectangle "FBaseTable + repository\nFAnnuncio, FUtenteRegistrato,\nFCarrello, FPagamento, ..." as Foundation
  rectangle "Entity E...\noggetti di dominio" as Entity
  rectangle "FDataBase\nPDO condiviso (singleton)" as DB
}

database "MySQL / MariaDB\nnerdvault" as MySQL

' ── Flusso della richiesta ───────────────────────────────
Client --> Htaccess : richiesta HTTP
Htaccess --> Index : inoltra
Index --> Front : handle()
Index --> DB : init(PDO)

Front --> Request : legge input e file
Front --> Session : controlli accesso
Front --> Csrf : valida token POST
Front --> Middleware : applica filtri
Request --> Upload : crea da $_FILES
Front --> Controllers : dispatch controller/action

Controllers --|> Base
Controllers --> Services : email / errori applicativi
Controllers --> PM : legge / scrive dati
Base --> Smarty : render view

' ── View ─────────────────────────────────────────────────
Smarty --> Normalizer : prepara dati
Smarty --> Session : legge stato sessione
Smarty --> Templates : display()
Smarty --> Client : HTML

' ── Persistenza ──────────────────────────────────────────
PM --> Foundation : delega operazioni
Foundation --> Entity : crea / idrata entity
Foundation --> DB : usa PDO
DB --> MySQL : query SQL

@enduml
